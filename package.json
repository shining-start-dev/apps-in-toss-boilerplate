{
  "name": "apps-in-toss-boilerplate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/@apps-in-toss/web-framework/bin.js dev",
    "dev:web": "vite",
    "typecheck": "tsc -b --pretty false",
    "verify": "pnpm typecheck && pnpm lint && pnpm test",
    "verify:full": "pnpm verify && pnpm build:web",
    "build": "ait build",
    "build:web": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "format": "prettier . --cache --write",
    "format:check": "prettier . --check",
    "preview": "vite preview",
    "deploy": "pnpm build && npx ait deploy"
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "^2.0.5",
    "@emotion/react": "^11.14.0",
    "@sentry/react": "^10.42.0",
    "@toss/tds-colors": "^0.1.0",
    "@toss/tds-mobile": "^2.2.1",
    "@toss/tds-mobile-ait": "^2.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.4.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
